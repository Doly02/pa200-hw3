@{
    ViewBag.Title = "Home Page";
}

<div class="jumbotron">
    <h1>Azure Queue</h1>
    <p class="lead">Jednoduche odeslani zpravy do Azure Storage Queue pro dalsi zpracovani.</p>
</div>

<div class="row">
    <div class="col-md-8">
        @if (TempData["QueueSuccess"] != null)
        {
            <div class="alert alert-success">@TempData["QueueSuccess"]</div>
        }

        @if (TempData["QueueError"] != null)
        {
            <div class="alert alert-danger">@TempData["QueueError"]</div>
        }

        @using (Html.BeginForm("SendMessageToQueue", "Home", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="message">Zprava</label>
                <textarea id="message" name="message" class="form-control" rows="4" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Poslat do queue</button>
        }
    </div>
</div>
